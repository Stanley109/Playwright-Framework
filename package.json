{
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1"
  },
  "scripts": {
    "test:sit headless": "TEST_ENV=sit npx playwright test --project=chromium",
    "test:sit headed": "TEST_ENV=sit npx playwright test --project=chromium --headed",
    "test:uat headless": "TEST_ENV=uat npx playwright test --project=chromium",
    "test:uat headed": "TEST_ENV=uat npx playwright test --project=chromium --headed"
  }
}
